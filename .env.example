# Copy to .env and fill in your credentials.
# NEVER commit .env — it contains secrets.

# ─── KIS (한국투자증권) credentials ──────────────────────────────────
# Get these from https://apiportal.koreainvestment.com after registering.
# Use the paper-trading (모의투자) app key first while you test.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT=12345678-01   # CANO-ACNT_PRDT_CD format

# ─── backtest.co.kr auth (optional) ────────────────────────────────
# Only needed if you want to fetch your portfolio directly from the
# server. You can also provide a local JSON file on the command line.
KRXDATA_API_URL=https://backtest.co.kr
KRXDATA_TOKEN=   # Copy from your browser: DevTools → Application → Cookies → jwt

# ─── Execution guardrails ──────────────────────────────────────────
# Per-order KRW cap — refuses to submit a single order larger than this.
# Set conservatively while you gain confidence. Default: 5,000,000 KRW.
MAX_ORDER_KRW=5000000

# Maximum session duration (minutes). Trader aborts remaining orders
# after this time and reports unfilled quantity. Default: 30 minutes.
MAX_SESSION_MINUTES=30
